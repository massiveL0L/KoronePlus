{
  "manifest_version": 2,
  "name": "Korone+",
  "version": "1.1",
  "description": "Tweaker for Roblox Revival Korone",
  "browser_specific_settings": {
    "gecko": {
      "id": "massivetoo419@gmail.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
"permissions": [
  "storage",
  "https://koroneplus.neocities.org/*"
],
  "content_scripts": [
    {
      "matches": [
        "*://pekora.zip/*",
        "*://*.pekora.zip/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
